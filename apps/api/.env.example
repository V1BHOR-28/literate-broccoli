# Copy to .env (apps/api/.env) or export in your shell before running uvicorn.
# Never commit real secrets — see AGENTS.md "Never store sensitive secrets in code".

# Full PostgreSQL DSN. If set, POSTGRES_PASSWORD below is ignored.
# Example: postgresql://ai_pm:local-development-only@localhost:5432/ai_pm
DATABASE_URL=postgresql://ai_pm:local-development-only@localhost:5432/ai_pm

# Only consulted when DATABASE_URL is unset; mirrors docker-compose.yml.
POSTGRES_PASSWORD=local-development-only

# Comma-separated list of allowed CORS origins for the Next.js frontend.
CORS_ORIGINS=http://localhost:3000

# Required only for memory embedding and project chat.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_CHAT_MODEL=gemini-1.5-flash
MEMORY_RETRIEVAL_TOP_K=8
MEMORY_WORKER_POLL_SECONDS=2
